<style-scheme id="gruvbox-dark" _name="Gruvbox Dark" version="1.0">
  <author>Your Name</author>
  <_description>Gruvbox Dark color scheme</_description>

  <!-- Gruvbox Dark Palette -->
  <color name="background"      value="#282828"/>
  <color name="current-line"    value="#3c3836"/>
  <color name="selection"       value="#504945"/>
  <color name="foreground"      value="#ebdbb2"/>
  <color name="comment"         value="#928374"/>
  <color name="red"             value="#fb4934"/>
  <color name="green"           value="#b8bb26"/>
  <color name="yellow"          value="#fabd2f"/>
  <color name="blue"            value="#83a598"/>
  <color name="purple"          value="#d3869b"/>
  <color name="aqua"            value="#8ec07c"/>
  <color name="orange"          value="#fe8019"/>
  <color name="gray"            value="#a89984"/>
  <color name="white"           value="#ffffff"/>
  <color name="bone-white"      value="#ebdbb2"/>
  <color name="weird-gray"      value="#928374"/>

  <!-- Global Settings -->
  <style name="text"                     foreground="foreground" background="background"/>
  <style name="selection"                foreground="bone-white" background="selection"/>
  <style name="cursor"                   foreground="bone-white"/>
  <style name="secondary-cursor"         foreground="foreground"/>
  <style name="selection-unfocused"      foreground="background" background="gray"/>
  <style name="current-line"             background="current-line"/>
  <style name="line-numbers"             foreground="gray" background="background"/>
  <style name="background-pattern"       background="background"/>
  <style name="bracket-match"            foreground="yellow" background="background"/>
  <style name="bracket-mismatch"         foreground="red" background="background"/>
  <style name="search-match"             foreground="foreground" background="selection"/>

  <!-- Syntax Elements -->
  <style name="def:keyword"              foreground="red" bold="true"/>
  <style name="def:statement"            foreground="red"/>
  <style name="def:function"             foreground="blue"/>
  <style name="def:decimal"              foreground="purple"/>
  <style name="def:preprocessor"         foreground="aqua"/>
  <style name="def:type"                 foreground="yellow"/>
  <style name="def:character"            foreground="yellow"/>
  <style name="def:comment"              foreground="comment"/>
  <style name="def:number"               foreground="purple"/>
  <style name="def:string"               foreground="green"/>
  <style name="def:net-address-in-comment" foreground="aqua" italic="true" underline="true"/>
  <style name="def:underlined"           italic="true" underline="true"/>
  <style name="def:note"                 foreground="foreground" background="background" bold="true"/>
  <style name="def:error"                foreground="red" bold="true"/>
  <style name="def:escape"               foreground="purple"/>
  <style name="def:shebang"              foreground="red" bold="true"/>
  <style name="def:doc-comment-element" italic="true"/>
  <style name="def:identifier"           foreground="blue" bold="true"/>
  <style name="def:specials"              foreground="foreground" background="purple"/>
  <style name="def:variable"             foreground="orange"/>
  <style name="def:boolean"              foreground="red" bold="true"/>
  <style name="def:constant"             foreground="red"/>
  <style name="def:special-constant"     foreground="red" bold="true"/>

  <!-- Diff Highlighting -->
  <style name="diff:added-line"          foreground="green"/>
  <style name="diff:removed-line"        foreground="red"/>
  <style name="diff:changed-line"        foreground="yellow"/>
  <style name="diff:diff-file"           foreground="blue" bold="true"/>
  <style name="diff:location"            foreground="orange"/>
  <style name="diff:special-case"        foreground="foreground" bold="true"/>

  <!-- Markup / Documentation -->
  <style name="latex:command"            foreground="orange" bold="true"/>
  <style name="latex:include"            use-style="def:preprocessor"/>
  <style name="def:emphasis"             italic="true"/>
  <style name="def:strong-emphasis"      foreground="foreground" bold="true"/>
  <style name="def:inline-code"          foreground="background"/>
  <style name="def:insertion"            underline="single"/>
  <style name="def:deletion"             strikethrough="true"/>
  <style name="def:link-text"            foreground="aqua"/>
  <style name="def:link-symbol"          foreground="aqua" bold="true"/>
  <style name="def:link-destination"     italic="true" underline="single"/>
  <style name="def:heading"              foreground="yellow" bold="true"/>
  <style name="def:thematic-break"       foreground="orange" bold="true"/>
  <style name="def:preformatted-section" foreground="aqua"/>
  <style name="def:list-marker"          foreground="foreground" bold="true"/>

  <!-- Heading Scales -->
  <style name="def:heading0" scale="3.0"/>
  <style name="def:heading1" scale="2.5"/>
  <style name="def:heading2" scale="2.0"/>
  <style name="def:heading3" scale="1.7"/>
  <style name="def:heading4" scale="1.5"/>
  <style name="def:heading5" scale="1.3"/>
  <style name="def:heading6" scale="1.2"/>
</style-scheme>